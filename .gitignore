# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Test / coverage / type / lint caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.ruff_cache/
.mypy_cache/
.basedpyright/
.hypothesis/

# Environments
.venv/
venv/
.env
.env.*
!.env.example
!.env.example.jinja

# Docker secrets-as-files (real secrets stay local; .example is committed)
secrets/*
!secrets/*.example

# Logs
*.log

# Local databases (services often create these at runtime)
*.db
*.sqlite
*.sqlite3

# Misc caches / notebooks
.cache/
.ipynb_checkpoints/

# Editor / OS
.vscode/*.local
.idea/
.DS_Store
*.swp

# Agentic CLI local state (project .claude/settings.json + hooks ARE committed)
.claude/settings.local.json
.codex/
.aider*
