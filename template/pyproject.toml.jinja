[project]
name = "{{ pkg_dist_name }}"
description = "{{ description }}"
readme = "README.md"
{% if license != "Proprietary" -%}
license = "{{ license }}"
license-files = ["LICENSE"]
{% endif -%}
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
requires-python = ">={{ python_min }}"
classifiers = [
    "Development Status :: 3 - Alpha",
    "Intended Audience :: Developers",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: {{ python_min }}",
{% if python_default != python_min %}    "Programming Language :: Python :: {{ python_default }}",
{% endif %}    "Typing :: Typed",
]
dependencies = [
{% if project_type == "service" %}    "fastapi>=0.115",
    "uvicorn[standard]>=0.30",
    "pydantic-settings>=2.2",
{% if include_mcp_server %}    "mcp>=1.28",
{% endif %}{% endif %}]
dynamic = ["version"]

[project.urls]
Homepage = "https://github.com/{{ repo_owner }}/{{ repo_name }}"
Source = "https://github.com/{{ repo_owner }}/{{ repo_name }}"
Issues = "https://github.com/{{ repo_owner }}/{{ repo_name }}/issues"
Changelog = "https://github.com/{{ repo_owner }}/{{ repo_name }}/blob/main/CHANGELOG.md"
{% if include_extras_example %}
[project.optional-dependencies]
# Worked example: an optional capability gated behind an extra. Install with
# `uv sync --extra pretty` (or `pip install {{ pkg_dist_name }}[pretty]`).
pretty = ["rich>=13"]
{% endif %}
{% if project_type == "service" %}
[project.scripts]
{{ pkg_dist_name }} = "{{ package_name }}.__main__:main"
{% if include_mcp_server %}{{ pkg_dist_name }}-mcp = "{{ package_name }}.mcp_server:main"
{% endif %}{% endif %}
[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.version]
path = "src/{{ package_name }}/__version__.py"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[tool.hatch.build.targets.sdist]
include = [
    "src/{{ package_name }}",
    "README.md",
    "CHANGELOG.md",
    "pyproject.toml",
{% if license != "Proprietary" %}    "LICENSE",
{% endif %}]
exclude = ["tests"]

[dependency-groups]
dev = [
    { include-group = "test" },
    { include-group = "lint" },
    { include-group = "type" },
    "pre-commit>=4",
]
test = [
    "pytest>=8",
    "pytest-asyncio>=0.23",
    "pytest-cov>=6",
    "coverage[toml]>=7.6",
{% if project_type == "service" %}    "httpx>=0.27",
{% endif %}{% if include_integration_tests %}    "testcontainers>=4",
{% endif %}]
lint = [
    "ruff>=0.11",
    "codespell>=2.3",
]
type = [
    "basedpyright>=1.20",
]
{% if include_docs_site %}docs = [
    "mkdocs-material>=9.5",
    "mkdocstrings[python]>=0.26",
]
{% endif %}
[tool.uv]
# Floor the uv binary so contributors/CI/Docker resolve an identical uv.lock.
required-version = ">=0.5.14"

[tool.ruff]
target-version = "py{{ python_min | replace('.', '') }}"

[tool.ruff.lint]
select = [
    "F", "E", "W", "I", "UP", "B", "SIM", "C4", "RUF", "S",
    "A", "PT", "RET", "PTH", "FA", "TC", "ARG", "T20",
]
ignore = [
    "E501",   # line length handled by the formatter
    "B008",   # function calls in argument defaults (FastAPI Depends idiom)
    "RET504", # unnecessary assignment before return
    "UP046",  # PEP 695 generics (class X[T]) — illegal on the 3.11 support floor
    "UP047",  # PEP 695 generic functions — same reason
]

[tool.ruff.lint.per-file-ignores]
"tests/**/*.py" = ["S101", "S105", "S106", "S311", "ARG", "B011"]
{% if project_type == "service" %}# FastAPI resolves route annotations at runtime, so TC (move-to-TYPE_CHECKING) misfires here.
"src/{{ package_name }}/app.py" = ["TC"]
{% endif %}

[tool.ruff.lint.isort]
known-first-party = ["{{ package_name }}"]

[tool.ruff.lint.pyupgrade]
keep-runtime-typing = true

[tool.pytest.ini_options]
addopts = "--import-mode=importlib --strict-markers --strict-config -ra -m 'not integration'"
filterwarnings = [
    "error",
{% if include_mcp_server %}    # MCP stateless-http leaves an anyio stream for GC; its __del__ surfaces a
    # benign unraisable warning at teardown. Scoped narrowly so all else stays strict.
    "ignore:Exception ignored in:pytest.PytestUnraisableExceptionWarning",
{% endif %}]
xfail_strict = true
asyncio_mode = "auto"
asyncio_default_fixture_loop_scope = "function"
markers = [
    "integration: requires docker/containers (deselected by default)",
]

[tool.coverage.run]
source = ["src/{{ package_name }}"]
omit = [
{% if project_type == "service" %}    "src/{{ package_name }}/__main__.py",
{% if include_mcp_server %}    "src/{{ package_name }}/mcp_server.py",
{% endif %}{% endif %}{% if include_extras_example %}    "src/{{ package_name }}/pretty.py",
{% endif %}]

[tool.coverage.report]
show_missing = true
sort = "-Cover"
fail_under = 80
