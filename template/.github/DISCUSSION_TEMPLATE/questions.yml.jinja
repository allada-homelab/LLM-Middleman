title: "[Question]: "
labels: ["question"]
body:
  - type: markdown
    attributes:
      value: |
        Thanks for using **{{ project_name }}**! Please fill out the form below so we
        can help efficiently. Search existing discussions and issues first — your
        question may already be answered.
  - type: textarea
    id: question
    attributes:
      label: Question
      description: What are you trying to do, and what's the question?
    validations:
      required: true
  - type: textarea
    id: reproduction
    attributes:
      label: Minimal example
      description: Code, commands, or steps that show the problem (formatted as code).
      render: shell
  - type: input
    id: version
    attributes:
      label: "{{ project_name }} version"
  - type: input
    id: python
    attributes:
      label: Python version
  - type: textarea
    id: context
    attributes:
      label: Additional context
      description: OS, environment, logs, anything else relevant.
