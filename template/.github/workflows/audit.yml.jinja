name: audit

# Scan uv.lock against the OSV vulnerability database. A pinned lockfile rots
# into known-CVE territory over time with no signal; the daily cron surfaces
# newly-disclosed advisories without needing a code change. ``uv audit`` reads
# uv.lock directly — no sync, no interpreter needed.
on:
  push:
    branches: [main]
  pull_request:
    types: [opened, synchronize]
  schedule:
    - cron: "0 6 * * *"
  workflow_dispatch:

permissions:
  contents: read

jobs:
  audit:
    runs-on: ${{ '{{' }} vars.CI_RUNNER || '{{ ci_runner_default }}' {{ '}}' }}
    steps:
      - uses: actions/checkout@v7
      - uses: astral-sh/setup-uv@v7
      # --no-dev: only gate on vulnerabilities reachable in shipped deps.
      - run: uv audit --no-dev
