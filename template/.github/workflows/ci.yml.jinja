name: CI

on:
  push:
    branches: [main]
  pull_request:
    types: [opened, synchronize]

jobs:
  test:
    runs-on: ${{ '{{' }} vars.CI_RUNNER || '{{ ci_runner_default }}' {{ '}}' }}
    strategy:
      fail-fast: false
      matrix:
        python-version: ["{{ python_min }}"{% if python_default != python_min %}, "{{ python_default }}"{% endif %}]
    steps:
      - uses: actions/checkout@v7
      - name: Log in to Docker Hub
        # Authenticated pulls lift the anonymous rate limit (100 pulls / 6h
        # per IP, trivially exhausted by a self-hosted runner pool) to 10k/6h.
        # Skipped when secrets are unavailable (e.g. Dependabot PRs) — falls
        # back to anonymous pulls.
        env:
          DOCKERHUB_USERNAME: {% raw %}${{ secrets.DOCKERHUB_USERNAME }}{% endraw %}
          DOCKERHUB_TOKEN: {% raw %}${{ secrets.DOCKERHUB_TOKEN }}{% endraw %}
        if: env.DOCKERHUB_USERNAME != '' && env.DOCKERHUB_TOKEN != ''
        uses: docker/login-action@v4
        with:
          username: {% raw %}${{ secrets.DOCKERHUB_USERNAME }}{% endraw %}
          password: {% raw %}${{ secrets.DOCKERHUB_TOKEN }}{% endraw %}
      - uses: actions/setup-python@v6
        with:
          python-version: {% raw %}${{ matrix.python-version }}{% endraw %}
      - uses: astral-sh/setup-uv@v7
        with:
          enable-cache: true
      - run: uv sync --locked --all-extras --all-groups
      - run: uv run ruff check .
      - run: uv run ruff format --check .
      - run: uv run basedpyright
      - run: uv run pytest -q -m "not integration"
      - name: Coverage (primary Python, gated)
        # The pyproject ``fail_under`` threshold gates this step; only run on
        # the default interpreter to avoid duplicate coverage churn.
        if: matrix.python-version == '{{ python_default }}'
        run: |
          uv run coverage run -m pytest -m "not integration"
          uv run coverage report
