# Validates PR titles match Conventional Commits.
#
# Format: <type>(<scope>): <imperative summary>
# Example: feat(api): add pagination to list endpoint

name: pr-title

on:
  pull_request:
    types: [opened, edited, synchronize, reopened]

permissions:
  pull-requests: read

jobs:
  validate:
    name: validate
    runs-on: ${{ '{{' }} vars.CI_RUNNER || '{{ ci_runner_default }}' {{ '}}' }}
    timeout-minutes: 5
    steps:
      - uses: amannn/action-semantic-pull-request@v6
        env:
          GITHUB_TOKEN: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
        with:
          # Conventional Commits types we accept.
          types: |
            feat
            fix
            docs
            style
            refactor
            perf
            test
            build
            ci
            chore
          subjectPattern: ^[a-z].+[^.]$
          subjectPatternError: |
            The subject "{subject}" doesn't follow our convention:
              - Must start with a lowercase letter
              - Must not end with a period
              - Should be an imperative summary ("add X", not "added X")
