name: docker-publish

on:
  push:
    branches: [main]   # publish an edge image on every merge to main
    tags: ["v*"]       # publish a versioned release on v* tags
  workflow_dispatch:
    inputs:
      tag:
        description: "Image tag to build (e.g. v0.1.0); defaults to an edge build from main."
        required: false

concurrency:
  group: {% raw %}docker-publish-${{ github.event.inputs.tag || github.ref_name }}{% endraw %}

  cancel-in-progress: false

permissions:
  contents: read
  packages: write
  id-token: write
  attestations: write

jobs:
  build-push:
    runs-on: ${{ '{{' }} vars.CI_RUNNER || '{{ ci_runner_default }}' {{ '}}' }}

    steps:
      - uses: actions/checkout@v7

      - name: Log in to Docker Hub
        env:
          DOCKERHUB_USERNAME: {% raw %}${{ secrets.DOCKERHUB_USERNAME }}{% endraw %}

          DOCKERHUB_TOKEN: {% raw %}${{ secrets.DOCKERHUB_TOKEN }}{% endraw %}

        if: env.DOCKERHUB_USERNAME != '' && env.DOCKERHUB_TOKEN != ''
        uses: docker/login-action@v4
        with:
          username: {% raw %}${{ secrets.DOCKERHUB_USERNAME }}{% endraw %}

          password: {% raw %}${{ secrets.DOCKERHUB_TOKEN }}{% endraw %}

      - name: Log in to GHCR
        uses: docker/login-action@v4
        with:
          registry: ghcr.io
          username: {% raw %}${{ github.actor }}{% endraw %}

          password: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}

      - uses: docker/setup-buildx-action@v3

      - name: Image metadata
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: {% raw %}ghcr.io/${{ github.repository }}{% endraw %}

          tags: |
            type=semver,pattern={% raw %}{{version}}{% endraw %}
            type=semver,pattern={% raw %}{{major}}.{{minor}}{% endraw %}
            type=sha
            type=edge,branch=main

      - name: Build and push
        id: build
        uses: docker/build-push-action@v6
        with:
          context: .
          push: true
          tags: {% raw %}${{ steps.meta.outputs.tags }}{% endraw %}

          labels: {% raw %}${{ steps.meta.outputs.labels }}{% endraw %}

          provenance: true
          sbom: true
          cache-from: type=gha
          cache-to: type=gha,mode=max
